<?xml version="1.0" encoding="utf-8"?>
<rbd>
  <time start="0" end="1000" step="1"/>
  <components>
    <component name="C1" >
      <weibull lambda="1000.0" k="10" outputFilename="C1.csv"/>
    </component>
    <component name="C2" >
      <exponential lambda="6.0e-4" outputFilename="C2.csv"/>
    </component>
    <component name="C3" >
      <custom filename="C3.csv"/>
    </component>
  </components>
  <blocks system="B4">
    <block outputFilename="B4.csv">
      <seriesGeneric>
        <input name="B1"/>
        <input name="B3"/>
        <output name="B4"/>
      </seriesGeneric>
    </block>
    <block outputFilename="B3.csv">
      <koonIdentical numInputs="3" minInputs="2">
        <input name="B2"/>
        <output name="B3"/>
      </koonIdentical>
    </block>
    <block outputFilename="B2.csv">
      <seriesGeneric>
        <input name="C2"/>
        <input name="C3"/>
        <output name="B2"/>
      </seriesGeneric>
    </block>
    <block outputFilename="B1.csv">
      <parallelIdentical numInputs="2">
        <input name="C1"/>
        <output name="B1"/>
      </parallelIdentical>
    </block>
  </blocks>
</rbd>
